# ── Backend env vars (set these on Railway) ──────────────────────────────────

# Your Vercel frontend URL — added to CORS allow-list.
FRONTEND_URL=https://trace-zero.vercel.app

# Auto-capture settings. On startup the backend captures real Binance L2 data
# if data/ is empty, then serves it for all subsequent simulation runs.
# Set AUTO_CAPTURE=false to disable (e.g. local dev).
AUTO_CAPTURE=true
CAPTURE_SYMBOL=BTCUSDT
CAPTURE_SECONDS=60
